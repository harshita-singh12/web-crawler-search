# Copy this file to .env and adjust as needed. .env is gitignored -- never
# commit real secrets. The values below are placeholders / safe local
# defaults, not real credentials.

# --- Postgres ---------------------------------------------------------
POSTGRES_USER=crawler
POSTGRES_PASSWORD=changeme_local_dev_only
POSTGRES_DB=crawler
POSTGRES_PORT=5432
# Full DSN used directly by services when NOT running via docker-compose
# (e.g. `postgresql://crawler:changeme_local_dev_only@localhost:5432/crawler`)
POSTGRES_DSN=postgresql://crawler:changeme_local_dev_only@localhost:5432/crawler

# --- Redis --------------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# --- MinIO (S3-compatible raw page storage) -----------------------------
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_change_me
MINIO_BUCKET=raw-pages
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# Host:port form used by the Python services (no scheme).
MINIO_ENDPOINT=localhost:9000
MINIO_SECURE=false

# --- Crawler --------------------------------------------------------------
MAX_DEPTH=2
MAX_PAGES=200
DEFAULT_CRAWL_DELAY_SECONDS=3
NUM_WORKER_TASKS=4
ALLOW_OFFSITE_LINKS=false
RECRAWL_INTERVAL_HOURS=24
CRAWLER_USER_AGENT=wifey-search-bot/0.1 (+https://github.com/example/wifey; portfolio project)
CRAWLER_METRICS_PORT=9100
VISIBILITY_TIMEOUT_MS=300000

# --- Indexer ----------------------------------------------------------
PAGERANK_INTERVAL_SECONDS=30
PAGERANK_DAMPING=0.85
PAGERANK_ITERATIONS=20
INDEXER_METRICS_PORT=9101

# --- API ----------------------------------------------------------------
API_PORT=8000
PAGERANK_BOOST_ALPHA=2.0
CORS_ALLOW_ORIGINS=*
# The URL the browser (not other containers) will use to reach the API --
# baked into the frontend build. When running docker-compose on your own
# machine, http://localhost:8000 is correct as-is.
PUBLIC_API_BASE_URL=http://localhost:8000

# --- Frontend -------------------------------------------------------------
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8000

# --- Monitoring -----------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_local_dev_only
